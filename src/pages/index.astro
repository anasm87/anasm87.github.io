---
import '../styles/global.css';
import { getCollection, render } from 'astro:content';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';

const experienceEntries = await getCollection('experience');
const sortedExperience = experienceEntries.sort((a, b) => a.data.order - b.data.order);

const educationEntries = await getCollection('education');
const sortedEducation = educationEntries.sort((a, b) => a.data.order - b.data.order);

const projectEntries = await getCollection('projects');
const sortedProjects = projectEntries;

const portfolioEntries = await getCollection('portfolio');
const sortedPortfolio = portfolioEntries.sort((a, b) => a.data.order - b.data.order);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Anas Mhana - Senior Software Engineer</title>
</head>
<body class="bg-zinc-50 min-h-screen selection:bg-zinc-200 selection:text-zinc-900">
  <div class="max-w-5xl mx-auto px-6 py-16 antialiased text-zinc-800">
    <div class="space-y-16">
      
      <header class="flex flex-col-reverse sm:flex-row items-center sm:items-start justify-between gap-6">
        <div class="text-center sm:text-left">
          <h1 class="text-3xl font-semibold tracking-tight text-zinc-900">Anas Mhana</h1>
          <p class="text-zinc-600 mt-1 text-lg">Senior Software Engineer</p>
          
          <div class="flex flex-wrap justify-center sm:justify-start gap-4 mt-4 text-sm text-zinc-600">
            <span class="flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 15 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
              Munich, Germany
            </span>
            <a href="mailto:anasm87@gmail.com" class="flex items-center gap-1.5 hover:text-indigo-600 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              anasm87@gmail.com
            </a>
            <a href="https://github.com/anasm87" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 hover:text-indigo-600 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A4.8 4.8 0 0 0 8 18v4"/></svg>
              GitHub
            </a>
            <a href="https://www.linkedin.com/in/anas-mhana-62813816/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 hover:text-indigo-600 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
          </div>

          <a href="/Curriculum_Vitae.pdf" download class="inline-flex items-center gap-2 mt-6 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-md transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            Download CV
          </a>
        </div>
        <img src="/profile.jpg" alt="Anas Mhana" class="w-32 h-32 sm:w-40 sm:h-40 rounded-full object-cover shadow-sm border border-zinc-200 shrink-0" />
      </header>

      <section id="summary">
        <h2 class="text-xl font-medium tracking-tight border-l-4 border-indigo-500 pl-3 mb-6 text-zinc-900">Professional Summary</h2>
        <p class="text-zinc-700 leading-relaxed">
          Senior Software Engineer with 8 years of experience at the intersection of high-performance C++ development and Computer Vision. Proven track record in designing and optimizing real-time embedded software for ADAS and communication systems at industry leaders like Bosch, DENSO, and Rohde & Schwarz.
        </p>
      </section>

      <section id="projects">
        <h2 class="text-xl font-medium tracking-tight border-l-4 border-indigo-500 pl-3 mb-6 text-zinc-900">Engineering Projects</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {sortedProjects.map(async (entry) => {
            const { Content } = await render(entry);
            return (
              <div class="flex flex-col border border-zinc-200 bg-white p-6 rounded-xl shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300">
                <div class="flex-1">
                  <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-2 mb-2">
                    <h3 class="font-semibold text-zinc-900 text-xl group-hover:text-indigo-600 transition-colors">
                      <a href={`/projects/${entry.id}`}>{entry.data.title}</a>
                    </h3>
                    {entry.data.speedup_metric && (
                      <span class="inline-flex text-xs font-medium px-2 py-0.5 bg-emerald-50 text-emerald-700 rounded-full border border-emerald-100 self-start">
                        {entry.data.speedup_metric} speedup
                      </span>
                    )}
                  </div>
                  <div class="text-sm text-zinc-700 leading-relaxed [&>p]:mt-2 mb-4">
                    <Content />
                  </div>
                  <div class="mb-4">
                    {entry.data.tech_stack.map(tech => (
                      <span class="inline-block bg-indigo-50 text-indigo-700 text-xs px-2.5 py-1 rounded-md mr-2 mb-2 border border-indigo-100 font-medium">{tech}</span>
                    ))}
                  </div>
                  <div class="flex gap-4 text-sm font-medium text-zinc-600">
                    {entry.data.github_url ? (
                      <a href={entry.data.github_url} class="hover:text-zinc-900 underline underline-offset-2 decoration-zinc-300">GitHub</a>
                    ) : null}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </section>

      <section id="experience">
        <h2 class="text-xl font-medium tracking-tight border-l-4 border-indigo-500 pl-3 mb-6 text-zinc-900">Experience</h2>
        <div class="space-y-10">
          {sortedExperience.map(async (entry) => {
            const { Content } = await render(entry);
            return (
              <div>
                <div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-1 mb-1">
                  <h3 class="font-semibold text-zinc-900 text-lg">{entry.data.role}</h3>
                  <span class="text-sm text-zinc-500 tabular-nums shrink-0">
                    {entry.data.startDate} — {entry.data.endDate || 'Present'}
                  </span>
                </div>
                <div class="text-base text-zinc-700 font-medium mb-3">{entry.data.company} • {entry.data.location}</div>
                <div class="text-sm text-zinc-700 [&>ul]:list-disc [&>ul]:pl-5 [&>ul]:space-y-1 [&>ul]:mt-3">
                  <Content />
                </div>
              </div>
            );
          })}
        </div>
      </section>

      <section id="education">
        <h2 class="text-xl font-medium tracking-tight border-l-4 border-indigo-500 pl-3 mb-6 text-zinc-900">Education</h2>
        <div class="space-y-8">
          {sortedEducation.map(async (entry) => {
            const { Content } = await render(entry);
            return (
              <div>
                <div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-1 mb-1">
                  <h3 class="font-semibold text-zinc-900 text-lg">{entry.data.degree}</h3>
                  <span class="text-sm text-zinc-500 tabular-nums shrink-0">
                    {entry.data.startDate} — {entry.data.endDate || 'Present'}
                  </span>
                </div>
                <div class="text-base text-zinc-700 font-medium mb-2">{entry.data.institution} • {entry.data.location}</div>
                <div class="text-sm text-zinc-700 [&>p]:mt-2">
                  <Content />
                </div>
              </div>
            );
          })}
        </div>
      </section>

      <section id="videos">
        <h2 class="text-xl font-medium tracking-tight border-l-4 border-indigo-500 pl-3 mb-6 text-zinc-900">Video Demonstrations</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {sortedPortfolio.map(async (entry) => {
            const { Content } = await render(entry);
            return (
              <div class="flex flex-col border border-zinc-200 bg-white p-6 rounded-xl shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300">
                <h3 class="font-semibold text-zinc-900 text-lg mb-2">{entry.data.title}</h3>
                <div class="text-sm text-zinc-700 leading-relaxed mb-4">
                  <Content />
                </div>
                {entry.data.youtubeId && (
                  <div class="mt-auto pt-4">
                    <YouTubeEmbed videoId={entry.data.youtubeId} title={entry.data.title} />
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </section>

    </div>
    
    <footer class="mt-20 pt-8 border-t border-zinc-200">
      <p class="text-sm text-zinc-500">© 2026 Anas Mhana. All rights reserved.</p>
    </footer>

  </div>
</body>
</html>