---
interface Props {
  videoId: string;
  title: string;
}
const { videoId, title } = Astro.props;
---
<div class="aspect-video w-full rounded-md overflow-hidden bg-zinc-200 mt-4">
  <iframe
    class="w-full h-full"
    src={`https://www.youtube-nocookie.com/embed/${videoId}`}
    title={title}
    frameborder="0"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
  ></iframe>
</div>